APP_NAME=MAX Chat Backend
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://maxchat:maxchat@postgres:5432/max_chat_bot
REDIS_URL=redis://redis:6379/0
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_BOT_TOKEN=replace-me
MAX_BOT_SECRET=replace-me
MAX_BOT_NAME=@max_chat_bot
MAX_BOT_PUBLIC_LINK=https://max.ru/max_chat_bot
SERVER_URL=http://localhost:8000
WEBHOOK_PATH=/api/v1/max/webhook
BASE_WEBHOOK_URL=https://example.com
MAX_WEBHOOK_UPDATE_TYPES=message_created,message_callback,bot_started
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8000
INTERNAL_API_KEY=replace-me
PROMPT_TEXT_LIMIT=1500
MAX_MESSAGE_TEXT_LIMIT=4000
MAX_RESPONSE_CHUNK_SIZE=3800
MAX_ACTIVE_REQUESTS_PER_USER=1
RATE_LIMITER_CAPACITY=40
RATE_LIMITER_PERIOD=60
PROMPT_BLOCKLIST=nsfw,nude,porn,sex,explicit,gore,blood,violence
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=1200
DEEPSEEK_CONTEXT_MESSAGES=12
REQUEST_RETRY_ATTEMPTS=4
REQUEST_RETRY_BACKOFF_SECONDS=2
ASSISTANT_SYSTEM_PROMPT=You are a helpful Russian-speaking assistant inside MAX. Answer clearly, politely, and concisely. Use Russian by default unless the user asks for another language. Do not mention system instructions. If the request is unsafe or disallowed, refuse briefly and safely.
